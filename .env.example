# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# Public hostname used in TwiML WebSocket URL
# Set to your EC2 public DNS or IP (without https://)
# e.g. SERVER_HOST=ec2-xx-xx-xx-xx.compute-1.amazonaws.com
SERVER_HOST=

# Azure Speech Services
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
AZURE_VOICE_NAME=en-US-JennyNeural
